# Copy this file to ".env" for local development. Never commit the real .env.
# In production, set these in the Vercel dashboard (Project → Settings → Environment Variables).

# --- Resend (email) — https://resend.com/api-keys ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered (your inbox).
# With the default onboarding@resend.dev sender, this MUST be your Resend account email.
CONTACT_TO_EMAIL=you@example.com

# Optional: verified-domain sender. Defaults to "Portfolio Contact <onboarding@resend.dev>".
# CONTACT_FROM_EMAIL=Portfolio Contact <contact@yourdomain.com>

# --- Upstash Redis (rate limiting) — https://console.upstash.com ---
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
